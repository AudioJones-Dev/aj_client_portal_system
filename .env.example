NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZ1YXNzZ2ZhYm5iaXRjanpnYWJtIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA4NzczNzksImV4cCI6MjA5NjQ1MzM3OX0.FZN0cSEzk7dh_f7U0fOUjJDFLKy5uStHCr7hpvyrQGc
