# AJ Digital Client Portal — environment. Copy to .env.local. Dev runs on :7600.
#
# Leave everything blank to run in OPEN SEED-MODE (no auth, demo data) — ideal
# for local/preview. Fill these in to turn on real auth + live data.

# --- Clerk (auth) ---------------------------------------------------------
# https://dashboard.clerk.com → your app → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Where Clerk sends users for sign-in/up (these match the app routes):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Supabase (data) ------------------------------------------------------
